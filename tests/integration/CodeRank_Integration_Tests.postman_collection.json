              "raw": "{\n  \"title\": \"FizzBuzz Matrix\",\n  \"description\": \"Given an integer n, print numbers from 1 to n. For multiples of 3 print Fizz, for multiples of 5 print Buzz, for multiples of both print FizzBuzz.\",\n  \"difficulty\": \"HARD\",\n  \"constraints\": \"1 <= n <= 100\",\n  \"examples\": [\n    {\n      \"inputText\": \"5\",\n      \"outputText\": \"1\\n2\\nFizz\\n4\\nBuzz\",\n      \"explanation\": \"3 is divisible by 3 so Fizz. 5 is divisible by 5 so Buzz.\",\n      \"orderIndex\": 1\n    }\n  ],\n  \"testCases\": [\n    {\n      \"input\": \"5\",\n      \"expected\": \"1\\n2\\nFizz\\n4\\nBuzz\",\n      \"isSample\": true,\n      \"orderIndex\": 1\n    },\n    {\n      \"input\": \"15\",\n      \"expected\": \"1\\n2\\nFizz\\n4\\nBuzz\\nFizz\\n7\\n8\\nFizz\\nBuzz\\n11\\nFizz\\n13\\n14\\nFizzBuzz\",\n      \"isSample\": false,\n      \"orderIndex\": 2\n    },\n    {\n      \"input\": \"1\",\n      \"expected\": \"1\",\n      \"isSample\": false,\n      \"orderIndex\": 3\n    },\n    {\n      \"input\": \"3\",\n      \"expected\": \"1\\n2\\nFizz\",\n      \"isSample\": false,\n      \"orderIndex\": 4\n    },\n    {\n      \"input\": \"10\",\n      \"expected\": \"1\\n2\\nFizz\\n4\\nBuzz\\nFizz\\n7\\n8\\nFizz\\nBuzz\",\n      \"isSample\": false,\n      \"orderIndex\": 5\n    }\n  ]\n}"
