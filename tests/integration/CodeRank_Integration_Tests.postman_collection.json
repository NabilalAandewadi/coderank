            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{ADMIN_EMAIL}}\",\n  \"password\": \"{{ADMIN_PASSWORD}}\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/v1/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "v1", "auth", "login"]
