        {
          "name": "P1-S6: Poll for Python Verdict (Run After Delay)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Introduce a 3-second delay before polling to allow Kafka + Docker execution",
                  "const delay = ms => new Promise(resolve => setTimeout(resolve, ms));",
                  "delay(3000);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "var terminalStates = ['COMPLETED', 'FAILED', 'TIMEDOUT'];",
                  "pm.test('Execution status is terminal or still running', function () {",
                  "    pm.expect(['QUEUED','RUNNING','COMPLETED','FAILED','TIMEDOUT']).to.include(json.status);",
                  "});",
                  "if (terminalStates.includes(json.status)) {",
                  "    pm.test('Verdict is ACCEPTED', function () {",
                  "        pm.expect(json.verdict).to.equal('ACCEPTED');",
                  "    });",
                  "    pm.test('executionTimeMs is populated', function () {",
                  "        pm.expect(json.executionTimeMs).to.be.a('number');",
                  "    });",
                  "    pm.test('Source field is present', function () {",
                  "        pm.expect(['cache','db']).to.include(json.source);",
                  "    });",
                  "} else {",
                  "    console.log('Job still in-flight, status: ' + json.status + '. Re-run this request.');",
                  "    pm.test('Job is still executing — re-run to poll again', function () {",
                  "        pm.expect(true).to.be.true;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{USER_JWT}}" }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/v1/submissions/{{SUBMISSION_ID_P1}}/result",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "v1", "submissions", "{{SUBMISSION_ID_P1}}", "result"]
            }
          }
        }
