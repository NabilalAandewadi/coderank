            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{USER_JWT}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"language\": \"python\",\n  \"sourceCode\": \"import sys\\ninput_data = sys.stdin.read().split()\\nn = int(input_data[0])\\nnums = list(map(int, input_data[1:n+1]))\\ntarget = int(input_data[n+1])\\nlookup = {}\\nfor i, num in enumerate(nums):\\n    complement = target - num\\n    if complement in lookup:\\n        print(lookup[complement], i)\\n        break\\n    lookup[num] = i\\n\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/v1/problems/{{PROBLEM_ID_P1}}/submit",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "v1", "problems", "{{PROBLEM_ID_P1}}", "submit"]
            }
          }
