        },
        {
          "name": "P1-S2: Admin Creates Problem (Python — Two Sum)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has problem id', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.id).to.be.a('string').and.not.empty;",
                  "    pm.collectionVariables.set('PROBLEM_ID_P1', json.id);",
                  "});",
                  "pm.test('Response has problem slug', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.slug).to.be.a('string').and.not.empty;",
                  "    pm.collectionVariables.set('PROBLEM_SLUG_P1', json.slug);",
                  "});",
                  "pm.test('Problem title matches', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.title).to.equal('Two Sum');",
                  "});",
                  "pm.test('Problem difficulty is EASY', function () {",
                  "    var json = pm.response.json();",
