            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ADMIN_JWT}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Two Sum\",\n  \"description\": \"Given an array of integers nums and an integer target, return indices of the two numbers such that they add up to target. You may assume that each input would have exactly one solution.\",\n  \"difficulty\": \"EASY\",\n  \"constraints\": \"2 <= nums.length <= 10^4\\n-10^9 <= nums[i] <= 10^9\\n-10^9 <= target <= 10^9\",\n  \"examples\": [\n    {\n      \"inputText\": \"nums = [2,7,11,15], target = 9\",\n      \"outputText\": \"[0,1]\",\n      \"explanation\": \"Because nums[0] + nums[1] == 9, we return [0, 1].\",\n      \"orderIndex\": 1\n    }\n  ],\n  \"testCases\": [\n    {\n      \"input\": \"2\\n2 7 11 15\\n9\",\n      \"expected\": \"0 1\",\n      \"isSample\": true,\n      \"orderIndex\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/v1/problems",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "v1", "problems"]
            }
          }
        },
        {
          "name": "P1-S2b: RBAC Guard — Standard User CANNOT Create Problem (Expect 403)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// This test uses ADMIN_JWT intentionally set to a fake token to simulate a user with no admin role.",
                  "// Actually we use USER_JWT here — if USER_JWT is empty this test is skipped gracefully.",
                  "// This step is re-run after user registration in S3 with USER_JWT."
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var userJwt = pm.collectionVariables.get('USER_JWT');",
                  "if (userJwt && userJwt.length > 0) {",
                  "    pm.test('Standard User receives 403 Forbidden on Problem Create', function () {",
                  "        pm.response.to.have.status(403);",
                  "    });",
                  "} else {",
                  "    pm.test('RBAC guard test skipped — USER_JWT not yet available', function () {",
                  "        pm.expect(true).to.be.true;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{USER_JWT}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Should Fail\",\n  \"description\": \"This request should be rejected by RBAC.\",\n  \"difficulty\": \"EASY\",\n  \"testCases\": [\n    {\n      \"input\": \"1\",\n      \"expected\": \"1\",\n      \"isSample\": true,\n      \"orderIndex\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/v1/problems",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "v1", "problems"]
            }
          }
        },
