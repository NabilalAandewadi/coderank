# ============================================================
# CodeRank — .gitignore
# ============================================================

# ----- Project-specific exclusions -----
Code_builder.py
codebase_context.txt
file_architecture.html
file_architecture.py
file_architecture.txt
files.txt

# ----- Maven -----
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# ----- IntelliJ IDEA -----
.idea/
*.iws
*.iml
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/

# ----- Eclipse -----
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# ----- VS Code -----
.vscode/

# ----- Spring Boot -----
spring-shell.log

# ----- Logs -----
*.log
logs/
log/

# ----- OS Files -----
.DS_Store
Thumbs.db
desktop.ini

# ----- Environment & Secrets -----
.env
.env.*
application-local.yml
application-local.properties
**/src/main/resources/application-secret*

# ----- Docker -----
docker-compose.override.yml

# ----- Test output -----
/test-output/
htmlReport/

# ----- Node (if any frontend tooling) -----
node_modules/
npm-debug.log*